      { "name": "rödlök", "amount": 200, "unit": "g", "count": 2, "countUnit": "st", "group": "Garnering", "cat": "grönt" },
      { "name": "sivri (turkisk paprika) eller grön paprika", "amount": 150, "unit": "g", "group": "Garnering", "cat": "grönt" },
      { "name": "tomat", "amount": 360, "unit": "g", "count": 3, "countUnit": "st", "group": "Garnering", "cat": "grönt" },
