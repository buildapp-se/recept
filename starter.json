      { "name": "stjälkselleri", "amount": 80, "unit": "g", "count": 2, "countUnit": "stjälkar", "cat": "grönt" },
      { "name": "vitlök", "amount": 20, "unit": "g", "count": 4, "countUnit": "klyftor", "cat": "grönt" },
      { "name": "olivolja", "amount": 100, "unit": "ml", "cat": "skafferi" },
      { "name": "tomatpuré", "amount": 90, "unit": "ml", "cat": "skafferi" },
      { "name": "rött vin (eller vatten)", "amount": 200, "unit": "ml", "cat": "övrigt" },
      { "name": "krossade tomater", "amount": 800, "unit": "g", "cat": "skafferi" },
      { "name": "torkad oregano", "amount": 3, "unit": "g", "cat": "skafferi" },
      { "name": "torkad timjan", "amount": 2, "unit": "g", "cat": "skafferi" },
      { "name": "lagerblad", "amount": 1, "unit": "g", "count": 2, "countUnit": "st", "cat": "skafferi" },
