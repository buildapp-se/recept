      { "name": "grönsaksbuljongtärning", "amount": 22, "unit": "g", "count": 2, "countUnit": "st", "group": "Lins- och tomatsås", "cat": "skafferi" },
      { "name": "tomatpuré", "amount": 30, "unit": "ml", "group": "Lins- och tomatsås", "cat": "skafferi" },
